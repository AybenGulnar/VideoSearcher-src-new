<?xml version="1.0" encoding="UTF-8"?>
<!--
  VideoSearcher Light Load Test - 6 phases, exponential think time
  =================================================================
  Target  : POST /process?video=video_cut.mp4  (API Gateway → Lambda → Step Functions)
  Phases  : 5 → 10 → 15 → 5 → 10 → 15 users, each phase lasting 'phaseduration' seconds
  Think time: exponential distribution with mean=20000ms (-ln(U)*20000 in JSR223Timer)

  MINI TEST (~6 minutes, phaseduration=60):
    jmeter -n -t videosearcher-http-test.jmx -Jphaseduration=60 \
      -l results/mini-raw.jtl -e -o results/mini-report

  FULL TEST (~1 hour, phaseduration=600):
    jmeter -n -t videosearcher-http-test.jmx -Jphaseduration=600 \
      -l results/full-raw.jtl -e -o results/full-report

  To run remotely use: ./run-test-on-ec2.sh -k key.pem -h <ec2-ip> -p 600
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="VideoSearcher Light Load Test">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <!-- API_HOST and API_PATH are defined here so they can be overridden
               with -JAPI_HOST=... on the command line without editing the file -->
          <elementProp name="API_HOST" elementType="Argument">
            <stringProp name="Argument.name">API_HOST</stringProp>
            <stringProp name="Argument.value">YOUR-API-ID.execute-api.YOUR-REGION.amazonaws.com</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="API_PATH" elementType="Argument">
            <stringProp name="Argument.name">API_PATH</stringProp>
            <stringProp name="Argument.value">/prod/process</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- setUp runs once before any thread group and computes the absolute start
           delay for each phase as a multiple of phaseduration (e.g. phase2 starts
           at 1×pd, phase3 at 2×pd, …, phase6 at 5×pd) -->
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp - Compute Phase Delays">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </SetupThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Set Phase Delays">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
int pd = props.get(&quot;phaseduration&quot;) ? props.get(&quot;phaseduration&quot;).toInteger() : 60
props.put(&quot;phase2delay&quot;, (pd * 1).toString())
props.put(&quot;phase3delay&quot;, (pd * 2).toString())
props.put(&quot;phase4delay&quot;, (pd * 3).toString())
props.put(&quot;phase5delay&quot;, (pd * 4).toString())
props.put(&quot;phase6delay&quot;, (pd * 5).toString())
// Think time: Exponential distribution, mean=20000ms, via JSR223Timer: -ln(U)*20000
log.info(&quot;=== Phase delays: pd=&quot; + pd
  + &quot; | P2=&quot; + props.get(&quot;phase2delay&quot;)
  + &quot; | P3=&quot; + props.get(&quot;phase3delay&quot;)
  + &quot; | P4=&quot; + props.get(&quot;phase4delay&quot;)
  + &quot; | P5=&quot; + props.get(&quot;phase5delay&quot;)
  + &quot; | P6=&quot; + props.get(&quot;phase6delay&quot;)
  + &quot; | thinktime=exponential(mean=20000ms)&quot;)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

      <!-- ==================== Phase 1: 5 users (ramp-up) ==================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Phase 1 - 5 users (ramp-up)">
        <intProp name="ThreadGroup.num_threads">5</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <stringProp name="ThreadGroup.duration">${__P(phaseduration,600)}</stringProp>
        <longProp name="ThreadGroup.delay">0</longProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /process">
          <intProp name="HTTPSampler.connect_timeout">10000</intProp>
          <intProp name="HTTPSampler.response_timeout">30000</intProp>
          <stringProp name="HTTPSampler.domain">${API_HOST}</stringProp>
          <stringProp name="HTTPSampler.port">443</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">${API_PATH}?video=video_cut.mp4</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert HTTP 200; any other status code marks the sample as failed -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="HTTP 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <intProp name="Assertion.test_type">8</intProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
        <!-- Exponential think time: -ln(U)*20000 produces mean≈20s with realistic variance -->
        <JSR223Timer guiclass="TestBeanGUI" testclass="JSR223Timer" testname="Think Time (Exponential)">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">(long)(-Math.log(1 - Math.random()) * 20000)</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
        </JSR223Timer>
        <hashTree/>
      </hashTree>

      <!-- ==================== Phase 2: 10 users (load increase) ==================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Phase 2 - 10 users (load increase)">
        <intProp name="ThreadGroup.num_threads">10</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <stringProp name="ThreadGroup.duration">${__P(phaseduration,600)}</stringProp>
        <stringProp name="ThreadGroup.delay">${__P(phase2delay,60)}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /process">
          <intProp name="HTTPSampler.connect_timeout">10000</intProp>
          <intProp name="HTTPSampler.response_timeout">30000</intProp>
          <stringProp name="HTTPSampler.domain">${API_HOST}</stringProp>
          <stringProp name="HTTPSampler.port">443</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">${API_PATH}?video=video_cut.mp4</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="HTTP 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <intProp name="Assertion.test_type">8</intProp>
            <stringProp name="Assertion.custom_message"></stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
        <JSR223Timer guiclass="TestBeanGUI" testclass="JSR223Timer" testname="Think Time (Exponential)">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">(long)(-Math.log(1 - Math.random()) * 20000)</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
        </JSR223Timer>
        <hashTree/>
      </hashTree>

      <!-- ==================== Phase 3: 15 users (peak) ==================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Phase 3 - 15 users (peak)">
        <intProp name="ThreadGroup.num_threads">15</intProp>
        <intProp name="ThreadGroup.ramp_time">15</intProp>
        <stringProp name="ThreadGroup.duration">${__P(phaseduration,600)}</stringProp>
        <stringProp name="ThreadGroup.delay">${__P(phase3delay,120)}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
